{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information containing basic credentials.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user authentication ID." },
        "email": { "type": "string", "description": "The email of the user." },
        "displayName": { "type": "string", "description": "Display name of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp of user account." }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity task created by an authenticated user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique task ID." },
        "userId": { "type": "string", "description": "Unique owner authentication ID." },
        "title": { "type": "string", "description": "The title of the task." },
        "description": { "type": "string", "description": "A detailed description." },
        "dueDate": { "type": "string", "description": "Optional due datetime." },
        "reminderTime": { "type": "string", "description": "Optional reminder datetime." },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"], "description": "The completion importance level." },
        "completed": { "type": "boolean", "description": "Status of completion." },
        "createdAt": { "type": "number", "description": "Creation epoch timestamp." },
        "imageUrl": { "type": "string", "description": "Optional attachment URL." }
      },
      "required": ["id", "userId", "title", "priority", "completed", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "A collection containing user profile documents."
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Subcollection of tasks specifically nested under each owning user."
    }
  }
}
