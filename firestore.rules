rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256))
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidTask(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 256
        && (!('description' in data) || (data.description is string && data.description.size() <= 2048))
        && (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() <= 128))
        && (!('reminderTime' in data) || (data.reminderTime is string && data.reminderTime.size() <= 128))
        && data.priority is string && (data.priority == 'Low' || data.priority == 'Medium' || data.priority == 'High')
        && data.completed is bool
        && data.createdAt is int
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 4096));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming())
                       && incoming().userId == existing().userId
                       && incoming().email == existing().email
                       && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId);

      match /tasks/{taskId} {
        allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(taskId);
        allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(taskId)
                         && isValidTask(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(taskId)
                         && isValidTask(incoming())
                         && incoming().userId == existing().userId
                         && incoming().createdAt == existing().createdAt
                         && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'dueDate', 'reminderTime', 'priority', 'completed', 'imageUrl']);
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(taskId);
      }
    }
  }
}
